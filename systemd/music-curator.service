[Unit]
Description=Music Curator API Service
After=network.target

[Service]
User=root
Group=root
WorkingDirectory=/home/jehangir/music-curator
ExecStart=/home/jehangir/music-curator/.venv/bin/uvicorn src.api.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
Environment="PATH=/home/jehangir/music-curator/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

[Install]
WantedBy=multi-user.target
